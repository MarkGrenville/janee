{
  "name": "janee-functions",
  "version": "1.0.0",
  "description": "JaNee Cloud Functions — API, webhooks, triggers",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "test": "npx ts-node src/test-cli.ts",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": "18"
  },
  "packageManager": "pnpm@10.31.0",
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "firebase-admin": "^13.7.0",
    "firebase-functions": "^7.2.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "typescript": "^6.0.2"
  }
}
